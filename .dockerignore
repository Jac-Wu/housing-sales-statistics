# Node 依赖目录
**/node_modules/
**/.npm/

# 构建产物（会在 Docker 中重新构建）
frontend/dist/

# 开发环境文件
**/.env
**/.env.local
**/.env.*.local

# 日志文件
**/*.log
**/npm-debug.log*
**/yarn-debug.log*
**/yarn-error.log*

# 编辑器和 IDE 配置
**/.vscode/
**/.idea/
**/*.swp
**/*.swo
**/*~

# 操作系统文件
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# Git 文件
.git/
.gitignore
.gitattributes

# Docker 文件（不需要复制到镜像中）
Dockerfile
docker-compose.yml
.dockerignore

# 文档和说明
README.md
*.md
!backend/package.json

# 测试文件
**/test/
**/__tests__/
**/*.test.js
**/*.spec.js

# 临时文件和缓存
**/tmp/
**/.cache/
**/.vite/

# Cursor 配置
.cursor/